# Flask
FLASK_CONFIG=development
SECRET_KEY=replace-with-long-random-string
JWT_SECRET_KEY=replace-with-different-long-random-string

# Database (PostgreSQL)
DATABASE_URL=postgresql+psycopg2://telemetry:telemetry@localhost:5432/telemetry_dev

# Optional: SQLAlchemy pool recycle (seconds)
# SQLALCHEMY_POOL_RECYCLE=1800

# Auth
# BCRYPT_ROUNDS=12
# JWT_ACCESS_MINUTES=15
# JWT_REFRESH_DAYS=30

# Redis (leave empty to disable — app still runs)
REDIS_URL=

# Socket.IO — use same Redis URL across workers for pub/sub message queue
# SOCKETIO_MESSAGE_QUEUE=redis://localhost:6379/0
SOCKETIO_ASYNC_MODE=threading
SOCKETIO_CORS_ORIGINS=*

# Logging
LOG_LEVEL=INFO

# Dev server (run.py)
HOST=0.0.0.0
PORT=5000

# Testing only
# TEST_DATABASE_URL=sqlite:///:memory:
